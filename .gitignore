/frontend/node_modules
/backend/node_modules

# Build output
/frontend/dist
/frontend/out-tsc
/frontend/tmp
/backend/dist
/backend/build
/coverage
/frontend/coverage

# Angular and tooling cache
/.angular/cache
/frontend/.angular/cache
.sass-cache
/connect.lock
/libpeerconnection.log
testem.log
/typings

# Logs
npm-debug.log*
yarn-error.log*
